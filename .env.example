# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# App Store Connect API
APP_STORE_CONNECT_KEY_ID=your-key-id
APP_STORE_CONNECT_ISSUER_ID=your-issuer-id
APP_STORE_CONNECT_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXX.p8

# Project Paths
DAYIST_PROJECT_PATH=/path/to/your/project

# Optional: Webhook Secret for App Store Connect
WEBHOOK_SECRET=your-webhook-secret

# GitHub Integration
GITHUB_TOKEN=ghp_your_token_here      # Needs 'repo' scope for issue creation

# Slack User/Channel IDs
OWNER_SLACK_USER_ID=<your-slack-user-id>  # Used in @mention escalations; find via Slack profile
CODE_REVIEW_CHANNEL_ID=code-review   # Slack channel name for peer review posts

# Slack Terminal Tunnel (Phase 2)
# Backend: "max" = Claude Max subscription (zero API cost), "api" = Anthropic API
SESSION_BACKEND=api
# Model used in API mode (ignored in max mode)
SESSION_MODEL=claude-sonnet-4-6
# Set to "true" after onboarding completes — bot sets this automatically
ONBOARDING_COMPLETE=false
